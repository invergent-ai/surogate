{
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python-envs.defaultPackageManager": "ms-python.python:pip",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python-envs.pythonProjects": [],
    "python.analysis.include": [
        "./surogate/*.py",
        "./venv/lib/python3.12/site-packages/dstack/**/*.py",
        "./venv/lib/python3.12/site-packages/pyhelm3/**/*.py",
        "./venv/lib/python3.12/site-packages/prometheus_api_client/**/*.pyi",
    ],
    "python.terminal.activateEnvInCurrentTerminal": false,
    "python.analysis.exclude": ["**"],
    "python.analysis.indexing": false,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.supportRestructuredText": false,
    "python.analysis.enablePytestSupport": false,
    "python.analysis.inlayHints.pytestParameters": false,
    "python.analysis.autoImportCompletions": false,
    "files.associations": {
        "*.dbclient-js": "javascript",
        "*.py": "python",
        "stdexcept": "cpp",
        "optional": "cpp",
        "type_traits": "cpp",
        "limits": "cpp"
    },
    "files.watcherExclude": {
        "**/build/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/frontend/node_modules/**": true,
        "**/docs/build/**": true
    },
    "git.ignoreLimitWarning": true,
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "biome.lsp.bin": "/usr/local/bin/biome",
}